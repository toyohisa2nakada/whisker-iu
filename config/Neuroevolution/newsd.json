{
    "testGenerator": "neuroevolution",
    "algorithm": "newsdNeatest",
    "eventSelection": "activation",
    "populationSize": 50,
    "numberOfSpecies": 5,
    "parentsPerSpecies": 0.30,
    "ageSignificance": 1.0,
    "switchObjectiveCount": 10,
    "classificationType": "multiLabel",
    "extractor": "neuroevolution",
    "aTRepetitions": 0,
    "noviceMaxAge": 3,
    "chromosome": {
        "type": "neatChromosome",
        "activationFunction": "SIGMOID",
        "inputConnectionMethod": "fully"
    },
    "crossover": {
        "operator": "uniformNeatCrossover",
        "crossoverWithoutMutation": 0.25,
        "interspeciesRate": 0.001,
        "weightAverageRate": 0.5
    },
    "mutation": {
        "operator": "neatMutation",
        "mutationWithoutCrossover": 0.20,
        "mutationAddConnection": 0.1,
        "recurrentConnection": 0.1,
        "addConnectionTries": 10,
        "populationChampionNumberOffspring": 3,
        "populationChampionNumberClones": 1,
        "populationChampionConnectionMutation": 0.3,
        "mutationAddNode": 0.2,
        "mutateWeights": 0.8,
        "perturbationPower": 1,
        "mutateToggleEnableConnection": 0.1,
        "toggleEnableConnectionTimes": 3,
        "mutateEnableConnection": 0.03
    },
    "compatibility": {
        "distanceThreshold": 1.0,
        "distanceModifier": 0.2,
        "disjointCoefficient": 3,
        "excessCoefficient": 3,
        "weightCoefficient": 0.4
    },
    "fitnessFunction": {
        "type": "statement",
        "targets": []
    },
    "networkFitness": {
        "type": "manyObjectiveReliableStatement",
        "timeout": 10000,
        "stableCount": 10
    },
    "population": {
        "strategy": "global_solutions",
        "randomFraction": 0.3
    },
    "stoppingCondition": {
        "type": "combined",
        "conditions": [
            {
                "type": "optimal"
            },
            {
                "type": "fixedTime",
                "duration": 7200000
            }
        ]
    },
    "events": {
        "actionThreshold": 0.5,
        "skipFrame": 3,
        "typeNumberMagnitude": 100
    },
    "assertions": false,
    "minimizeAssertions": false
}

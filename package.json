{
    "name": "whisker",
    "version": "0.8.0",
    "description": "A Testing Utility for Scratch 3.0",
    "license": "GPL-3.0-only",
    "repository": {
        "type": "git",
        "url": "git+ssh://git@github.com/se2p/whisker-main"
    },
    "private": true,
    "workspaces": [
        "whisker-main",
        "whisker-web",
        "servant"
    ],
    "scripts": {
        "start": "yarn --cwd whisker-web start",
        "build": "yarn --cwd whisker-main build && yarn --cwd whisker-web build",
        "build:watch": "concurrently --names \"whisker-main,whisker-web\" \"yarn --cwd whisker-main build:watch\" \"yarn --cwd whisker-web build:watch\"",
        "build:clean": "yarn --cwd whisker-main build:clean && yarn --cwd whisker-web build:clean",
        "build-main": "yarn --cwd whisker-main build",
        "build-web": "yarn --cwd whisker-web build",
        "ci:prepare-downstream-build": "node .prepare-downstream-build.js",
        "lint": "yarn --cwd whisker-main lint && yarn --cwd whisker-web lint && yarn --cwd servant lint",
        "ci:lint": "yarn --cwd whisker-main ci:lint && yarn --cwd whisker-web ci:lint && yarn --cwd servant ci:lint",
        "servant": "yarn --cwd servant node servant.js",
        "test": "yarn --cwd whisker-main test && yarn --cwd servant unittest",
        "integrationtest": "yarn --cwd whisker-web test && yarn --cwd servant integrationtest",
        "clean:cache": "rm -rf **/.webpack-cache*",
        "dev": "npx serve ./whisker-web/dist"
    },
    "dependencies": {
        "@tensorflow/tfjs": "^4.22.0",
        "assert": "^2.0.0",
        "clean-yaml-object": "^0.1.0",
        "js-yaml": "^4.1.0",
        "lodash.clonedeep": "^4.5.0",
        "lodash.defaults": "^4.2.0",
        "lodash.isequal": "^4.5.0",
        "minilog": "^3.1.0",
        "ntc": "^0.0.1",
        "scratch-analysis": "git+https://gitlab+deploy-token-26:gldt-JnhezqQAx-v4JyLZBw7P@gitlab.infosun.fim.uni-passau.de/se2/scratch/scratch-analysis.git#main",
        "scratch-vm": "git+https://gitlab+deploy-token-3:i8XTz2vnGPewCoYALnoy@gitlab.infosun.fim.uni-passau.de/se2/scratch/scratch-vm.git#develop",
        "seed-random": "^2.2.0",
        "setimmediate": "^1.0.5",
        "source-map-loader": "^1.1.3",
        "xml-js": "^1.6.11",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@babel/core": "^7.15.5",
        "@babel/preset-env": "^7.15.6",
        "@types/jest": "28.1.5",
        "@types/node": "^16.9.1",
        "@typescript-eslint/eslint-plugin": "^5.14",
        "@typescript-eslint/parser": "^5.14",
        "babel-eslint": "^10.1.0",
        "babel-jest": "^28.1.3",
        "babel-loader": "^8.2.2",
        "babel-preset-minify": "^0.5.1",
        "concurrently": "^7.6.0",
        "copy-webpack-plugin": "^6.3.2",
        "css-loader": "^5.0.1",
        "eslint": "^7.32.0",
        "eslint-config-scratch": "^7.0.0",
        "eslint-plugin-node": "^11.1.0",
        "expose-loader": "^1.0.3",
        "file-url": "3.0.0",
        "imports-loader": "^1.2.0",
        "ink-docstrap": "^1.3.2",
        "jest": "^28.1.3",
        "jest-puppeteer": "^10.0.1",
        "jsdoc": "^3.6.7",
        "mini-css-extract-plugin": "^1.6.2",
        "optimize-css-assets-webpack-plugin": "^5.0.8",
        "tap": "^15.0.9",
        "ts-jest": "^28.0.5",
        "ts-loader": "^9.3.1",
        "ts-node": "^10.2.1",
        "typescript": "~4.6",
        "webpack": "^5.73.0",
        "webpack-cli": "^4.10.0",
        "jszip": "^3.10.1"
    }
}
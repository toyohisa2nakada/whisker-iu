{
    "name": "whisker-main",
    "version": "0.8.0",
    "description": "A Testing Utility for Scratch 3.0",
    "author": "Marvin Kreis",
    "license": "GPL-3.0-only",
    "homepage": "https://github.com/se2p/whisker-main",
    "repository": {
        "type": "git",
        "url": "git+ssh://git@github.com/se2p/whisker-main"
    },
    "main": "./src/index.js",
    "scripts": {
        "build": "tsc --incremental && webpack --color --bail",
        "build:watch": "tsc-watch --onFirstSuccess \"webpack --color --watch\"",
        "build:prod": "NODE_ENV=production webpack --color --bail",
        "build:clean": "if [ -d dist ]; then rm -rf dist; fi && tsc --incremental && webpack --color --bail",
        "test": "jest --forceExit --coverage --verbose",
        "watch": "concurrently -k -p \"[{name}]\" -n \"TypeScript,Node\" -c \"yellow.bold,cyan.bold,green.bold\" \"npm run watch-ts\" \"npm run watch-node\"",
        "watch-test": "npm run test -- --watchAll",
        "test:coverage": "npm test -- --coverage",
        "build-ts": "tsc --incremental",
        "watch-ts": "tsc -w",
        "docs": "jsdoc -c .jsdoc.json",
        "lint": "eslint .",
        "ci:lint": "eslint --quiet .",
        "lint:fix": "eslint . --fix"
    },
    "devDependencies": {
        "@fast-check/jest": "^2.0.3",
        "eslint-plugin-jest": "27",
        "tsc-watch": "^6.0.0"
    }
}
